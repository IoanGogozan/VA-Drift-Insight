generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ZoneType {
  water_meter_zone
  wastewater_catchment
}

enum PipeType {
  water
  wastewater
  stormwater
}

enum AssetType {
  zone
  pipe
  pump_station
}

enum IncidentType {
  leak
  pipe_break
  high_level_alarm
  overflow
  complaint
  pump_failure
  suspected_fremmedvann
}

enum ScoreType {
  leakage
  fremmedvann
  data_quality
  sanering
}

enum RecommendationType {
  leakage
  fremmedvann
  sanering
  data_gap
}

enum RecommendationPriority {
  high
  medium
  low
}

enum RecommendationStatus {
  new
  planned
  in_progress
  completed
  dismissed
}

enum WaterZoneStatus {
  normal
  suspect
  high
}

enum PrivateServiceCaseStatus {
  suspected
  contacted
  repaired
  closed
}

model Zone {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  zoneType           ZoneType @map("zone_type")
  population         Int?
  baselineNightFlow  Float?   @map("baseline_night_flow")
  currentNightFlow   Float?   @map("current_night_flow")
  dataQualityScore   Int?     @map("data_quality_score")
  geometry           Unsupported("geometry")?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  pipes        Pipe[]
  pumpStations PumpStation[] @relation("CatchmentPumpStations")
  waterZone    WaterZone?
  privateServiceCases PrivateServiceCase[]

  @@map("zones")
}

model PrivateServiceCase {
  id                 String                   @id @default(uuid()) @db.Uuid
  address            String
  zoneId             String                   @map("zone_id") @db.Uuid
  status             PrivateServiceCaseStatus @default(suspected)
  estimatedLossM3Day Float                    @map("estimated_loss_m3_day")
  lastFollowUp       DateTime?                @map("last_follow_up")
  nextFollowUp       DateTime?                @map("next_follow_up")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  zone Zone @relation(fields: [zoneId], references: [id])

  @@index([zoneId])
  @@index([status])
  @@map("private_service_cases")
}

model WaterZone {
  id                    String          @id @default(uuid()) @db.Uuid
  zoneId                String?         @unique @map("zone_id") @db.Uuid
  name                  String
  totalConsumptionM3Day Float           @map("total_consumption_m3_day")
  nightFlowM3h          Float           @map("night_flow_m3h")
  baselineNightFlowM3h  Float           @map("baseline_night_flow_m3h")
  estimatedLossM3Day    Float           @map("estimated_loss_m3_day")
  trend7d               Float           @default(0) @map("trend_7d")
  trend30d              Float           @default(0) @map("trend_30d")
  status                WaterZoneStatus
  geometry              Unsupported("geometry(Polygon, 4326)")?
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  zone Zone? @relation(fields: [zoneId], references: [id])

  @@index([status])
  @@map("water_zones")
}

model Pipe {
  id             String   @id @default(uuid()) @db.Uuid
  pipeCode       String   @unique @map("pipe_code")
  zoneId         String?  @map("zone_id") @db.Uuid
  material       String
  installedYear  Int?     @map("installed_year")
  diameterMm     Int?     @map("diameter_mm")
  pipeType       PipeType @map("pipe_type")
  criticality    Int      @default(50)
  previousBreaks Int      @default(0) @map("previous_breaks")
  geometry       Unsupported("geometry")?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  zone Zone? @relation(fields: [zoneId], references: [id])

  @@index([zoneId])
  @@map("pipes")
}

model PumpStation {
  id             String   @id @default(uuid()) @db.Uuid
  stationCode    String   @unique @map("station_code")
  name           String
  catchmentId    String?  @map("catchment_id") @db.Uuid
  capacityM3h    Float?   @map("capacity_m3h")
  alarmCount     Int      @default(0) @map("alarm_count")
  overflowEvents Int      @default(0) @map("overflow_events")
  geometry       Unsupported("geometry")?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  catchment Zone? @relation("CatchmentPumpStations", fields: [catchmentId], references: [id])

  @@index([catchmentId])
  @@map("pump_stations")
}

model NetworkNode {
  id        String   @id @default(uuid()) @db.Uuid
  nodeCode  String   @unique @map("node_code")
  nodeType  String   @map("node_type")
  pipeType  String?  @map("pipe_type")
  status    String   @default("normal")
  geometry  Unsupported("geometry(Point, 4326)")?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([nodeType])
  @@index([pipeType])
  @@map("network_nodes")
}

model TimeSeries {
  id                 String    @id @default(uuid()) @db.Uuid
  assetType          AssetType @map("asset_type")
  assetId            String    @map("asset_id")
  timestamp          DateTime
  flowM3h            Float?    @map("flow_m3h")
  pressureBar        Float?    @map("pressure_bar")
  levelM             Float?    @map("level_m")
  pumpRuntimeMinutes Int?      @map("pump_runtime_minutes")
  rainfallMm         Float?    @map("rainfall_mm")
  createdAt          DateTime  @default(now()) @map("created_at")

  @@index([assetType, assetId, timestamp])
  @@map("time_series")
}

model Incident {
  id           String       @id @default(uuid()) @db.Uuid
  incidentType IncidentType @map("incident_type")
  assetType    AssetType    @map("asset_type")
  assetId      String       @map("asset_id")
  occurredAt   DateTime     @map("occurred_at")
  description  String
  resolvedAt   DateTime?    @map("resolved_at")
  geometry     Unsupported("geometry")?
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([assetType, assetId, occurredAt])
  @@map("incidents")
}

model RiskScore {
  id           String    @id @default(uuid()) @db.Uuid
  assetType    AssetType @map("asset_type")
  assetId      String    @map("asset_id")
  scoreType    ScoreType @map("score_type")
  score        Int
  confidence   Int
  explanation  String
  calculatedAt DateTime  @default(now()) @map("calculated_at")

  @@index([assetType, assetId, scoreType])
  @@map("risk_scores")
}

model Recommendation {
  id              String                 @id @default(uuid()) @db.Uuid
  type            RecommendationType
  priority        RecommendationPriority
  assetType       AssetType              @map("asset_type")
  assetId         String                 @map("asset_id")
  areaName        String                 @map("area_name")
  reason          String
  suggestedAction String                 @map("suggested_action")
  status          RecommendationStatus   @default(new)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  @@index([priority, status])
  @@map("recommendations")
}

model Municipality {
  id               String   @id @default(uuid()) @db.Uuid
  municipalityCode String   @unique @map("municipality_code")
  name             String
  source           String
  geometry         Unsupported("geometry(MultiPolygon, 4326)")?
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("municipalities")
}

model WeatherObservation {
  id               String   @id @default(uuid()) @db.Uuid
  source           String
  stationId        String   @map("station_id")
  stationName      String?  @map("station_name")
  municipalityCode String?  @map("municipality_code")
  observedAt       DateTime @map("observed_at")
  rainfallMm       Float?   @map("rainfall_mm")
  temperatureC     Float?   @map("temperature_c")
  qualityCode      String?  @map("quality_code")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([source, stationId, observedAt])
  @@index([municipalityCode, observedAt])
  @@index([stationId, observedAt])
  @@map("weather_observations")
}

model ExternalDataSource {
  id          String   @id @default(uuid()) @db.Uuid
  sourceKey   String   @unique @map("source_key")
  name        String
  url         String
  description String
  isMvp       Boolean  @default(false) @map("is_mvp")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("external_data_sources")
}

model ImportRun {
  id            String   @id @default(uuid()) @db.Uuid
  importType    String   @map("import_type")
  status        String
  totalRows     Int      @default(0) @map("total_rows")
  acceptedRows  Int      @default(0) @map("accepted_rows")
  rejectedRows  Int      @default(0) @map("rejected_rows")
  warningCount  Int      @default(0) @map("warning_count")
  durationMs    Int      @default(0) @map("duration_ms")
  summary       Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  validationErrors ImportValidationError[]

  @@index([createdAt])
  @@index([status])
  @@map("import_runs")
}

model ImportValidationError {
  id          String   @id @default(uuid()) @db.Uuid
  importRunId String   @map("import_run_id") @db.Uuid
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  field       String
  severity    String
  message     String
  createdAt   DateTime @default(now()) @map("created_at")

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId])
  @@map("import_validation_errors")
}
